{
  "name": "cosmolauncher",
  "version": "1.0.0",
  "author": {
    "name": "CosmoLauncher",
    "email": "support@cosmolauncher.com"
  },
  "description": "CosmoLauncher — Minecraft Launcher",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build":       "electron-builder",
    "build:win":   "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:mac":   "electron-builder --mac"
  },
  "dependencies": {
    "minecraft-launcher-core": "^3.6.1",
    "axios":          "^1.6.0",
    "electron-store": "^8.1.0",
    "electron-log":   "^5.0.1",
    "electron-updater":"^6.1.7",
    "node-fetch":     "^2.7.0"
  },
  "devDependencies": {
    "electron":         "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId":       "com.cosmolauncher.app",
    "productName": "CosmoLauncher",
    "copyright":   "Copyright © 2024 CosmoLauncher",
    "asar": true,

    "directories": {
      "output":         "dist",
      "buildResources": "assets"
    },

    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],

    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CosmoLauncher",
      "runAfterFinish": true
    },

    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "category": "Game"
    },

    "publish": {
      "provider": "github",
      "owner":    "Orang786",
      "repo":     "cosmolauncher",
      "releaseType": "release"
    }
  }
}