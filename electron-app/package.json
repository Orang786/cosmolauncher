{
  "name": "cosmolauncher",
  "version": "1.0.0",
  "description": "CosmoLauncher — Minecraft Launcher",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "minecraft-launcher-core": "^3.6.1",
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.cosmolauncher.app",
    "productName": "CosmoLauncher",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}